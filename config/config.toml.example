# hc-sonos plugin configuration
# Copy to config/config.dev.toml and fill in your values.

# ---------------------------------------------------------------------------
# HomeCore broker connection
# ---------------------------------------------------------------------------
[homecore]
broker_host = "127.0.0.1"
broker_port = 1883
plugin_id   = "plugin.sonos"
# Password must match the entry in homecore's [[mqtt.clients]] section.
# Leave empty string if the broker has no auth configured.
password = ""

# ---------------------------------------------------------------------------
# Sonos discovery
# ---------------------------------------------------------------------------
[sonos]
# How often to re-run SSDP discovery (seconds).
discovery_interval_secs = 60

# SSDP scan duration — how long to listen for speaker responses (seconds).
discovery_timeout_secs = 5

# Optional: probe specific IPs in addition to SSDP.
# Useful for speakers on a different VLAN or when SSDP is blocked.
# manual_hosts = ["192.168.1.50", "192.168.1.51"]

# ---------------------------------------------------------------------------
# HTTP control API
#
# The plugin exposes a standalone Axum HTTP API on this host/port for direct
# Sonos commands (play, pause, volume, favorites, grouping, etc.).  This is
# completely separate from the HomeCore MQTT/REST API.
#
# Endpoints (all relative to http://{host}:{port}):
#   GET  /speakers                   — list all known speakers
#   POST /speakers/{hc_id}/play      — resume playback
#   POST /speakers/{hc_id}/pause     — pause playback
#   POST /speakers/{hc_id}/stop      — stop playback
#   POST /speakers/{hc_id}/volume    — body: { "volume": 40 }
#   POST /speakers/{hc_id}/mute      — body: { "muted": true }
#   POST /speakers/{hc_id}/next      — next track
#   POST /speakers/{hc_id}/prev      — previous track
#   POST /speakers/{hc_id}/favorite  — body: { "index": 0 }  (0-based favorites list)
#   POST /speakers/{hc_id}/join      — body: { "coordinator_hc_id": "sonos_living_room" }
#   POST /speakers/{hc_id}/unjoin    — remove from group, become standalone
# ---------------------------------------------------------------------------
[api]
# Interface to bind.  "0.0.0.0" listens on all interfaces (recommended for LAN).
# Use "127.0.0.1" to restrict to localhost only.
host    = "0.0.0.0"
port    = 5005
enabled = true

# IP or hostname that Sonos speakers can reach to deliver UPnP/GENA event
# callbacks (NOTIFY requests).  Required when host = "0.0.0.0" because Sonos
# needs a specific LAN IP to subscribe to — it cannot use 0.0.0.0.
# Set this to your server's LAN IP address.
callback_host = "192.168.1.10"

# ---------------------------------------------------------------------------
# Pre-configured speakers  (optional)
#
# Speakers discovered via SSDP that match a UUID here will use the specified
# hc_id, name, and area instead of the auto-generated values.
# Auto-generated hc_id = "sonos_{sanitized_room_name}" (e.g. "sonos_living_room").
#
# To find a speaker's UUID:  browse to http://{speaker_ip}:1400/xml/device_description.xml
# and look for the <UDN> element (strip the "uuid:" prefix).
# ---------------------------------------------------------------------------

# [[devices]]
# uuid  = "RINCON_347E5C3D12E401400"
# hc_id = "sonos_living_room"
# name  = "Living Room"
# area  = "living_room"

# [[devices]]
# uuid  = "RINCON_B8E937BB0E5001400"
# hc_id = "sonos_kitchen"
# name  = "Kitchen"
# area  = "kitchen"

# ---------------------------------------------------------------------------
# Log rotation and compression
# ---------------------------------------------------------------------------

[logging]
# Stderr log level when RUST_LOG is not set.
# Accepts tracing filter directives, e.g. "debug" or "hc_hue=debug,rumqttc=warn".
level = "info"

# Time-based rotation strategy.
# "daily" (default) | "hourly" | "weekly" | "never"
rotation = "daily"

# Rotate the active log file when it exceeds this many megabytes.
# Combined with `rotation` as "whichever comes first".
# Set to 0 to disable size-based rotation (time-only).
max_size_mb = 100

# Gzip-compress rotated files in a background thread.
# Active log file is never compressed; only rotated files are compressed.
compress = true
